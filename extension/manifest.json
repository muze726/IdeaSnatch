{
  "manifest_version": 3,
  "name": "灵感捕手",
  "version": "0.1.0",
  "description": "一键保存当前页面的标题、链接、选中文本、备注与标签，并可导出。",
  "action": {
    "default_title": "灵感捕手",
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "activeTab", "scripting", "downloads"],
  "host_permissions": ["<all_urls>"],
  "minimum_chrome_version": "114"
}
